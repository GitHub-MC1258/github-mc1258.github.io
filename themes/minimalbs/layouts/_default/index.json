{{- $.Scratch.Add "index" slice -}}
{{- /* On filtre ici pour exclure les pages où searchable est explicitement false */ -}}
{{- range (where .Site.RegularPages "Params.searchable" "!=" false) -}}
    {{- $.Scratch.Add "index" (dict "title" .Title "author" ( .Params.author | default .Site.Params.author ) "content" (.Plain | htmlUnescape | plainify) "permalink" .Permalink) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
