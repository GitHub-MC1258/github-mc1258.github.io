{{- $.Scratch.Add "index" slice -}}
{{- /* On filtre ici pour exclure les pages où searchable est explicitement false */ -}}
{{- range (where .Site.RegularPages "Params.searchable" "ne" false) -}}
  {{- if ne .Layout "search" -}}
        {{- $rawDate := .PublishDate | default .Date -}}
        {{- $formattedDate := "Date inconnue" -}}
            {{- if $rawDate -}}
            {{- $formattedDate = $rawDate.Format "02/01/2006" -}}
        {{- end -}}

    {{- $.Scratch.Add "index" (dict
     "title" .Title
     "author" ( .Params.author | default .Site.Params.author )
     "date" $formattedDate
     "content" (.Plain | htmlUnescape | plainify)
     "permalink" .Permalink) -}}
    {{- end -}}
  {{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
