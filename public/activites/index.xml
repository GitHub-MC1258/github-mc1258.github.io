<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Activites on Mon p'tit site</title><link>https://github-mc1258.github.io/activites/</link><description>Recent content in Activites on Mon p'tit site</description><generator>Hugo</generator><language>fr-FR</language><lastBuildDate>Mon, 08 Dec 2025 00:00:00 +0100</lastBuildDate><atom:link href="https://github-mc1258.github.io/activites/index.xml" rel="self" type="application/rss+xml"/><item><title>Parcours du 08/12/2025</title><link>https://github-mc1258.github.io/activites/20251208/</link><pubDate>Mon, 08 Dec 2025 00:00:00 +0100</pubDate><guid>https://github-mc1258.github.io/activites/20251208/</guid><description>&lt;p&gt;Parcours du 08/12/2025 exporté depuis Oruxmaps.&lt;/p&gt;
&lt;link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" /&gt;
&lt;script src="https://unpkg.com/leaflet/dist/leaflet.js"&gt;&lt;/script&gt;
&lt;script src="https://cdn.jsdelivr.net/npm/gpxparser/dist/GPXParser.min.js"&gt;&lt;/script&gt;

&lt;div class="activite-container" style="border: 1px solid #ddd; border-radius: 8px; overflow: hidden; font-family: sans-serif; margin: 20px 0;"&gt;
 &lt;div id="map-20251208.gpx" style="height: 350px; width: 100%;"&gt;&lt;/div&gt;

 &lt;div style="padding: 15px; background: #f9f9f9; display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px; text-align: center;"&gt;
 &lt;div&gt;&lt;small&gt;Distance&lt;/small&gt;&lt;br&gt;&lt;strong id="dist-20251208.gpx"&gt;-&lt;/strong&gt; km&lt;/div&gt;
 &lt;div&gt;&lt;small&gt;Temps&lt;/small&gt;&lt;br&gt;&lt;strong id="time-20251208.gpx"&gt;-&lt;/strong&gt;&lt;/div&gt;
 &lt;div&gt;&lt;small&gt;Dénivelé (+/-)&lt;/small&gt;&lt;br&gt;&lt;strong&gt;&lt;span id="elev-p-20251208.gpx"&gt;-&lt;/span&gt; / &lt;span id="elev-m-20251208.gpx"&gt;-&lt;/span&gt;&lt;/strong&gt; m&lt;/div&gt;
 &lt;div&gt;&lt;small&gt;Vitesse (Moy/Max)&lt;/small&gt;&lt;br&gt;&lt;strong&gt;&lt;span id="speed-av-20251208.gpx"&gt;-&lt;/span&gt; / &lt;span id="speed-mx-20251208.gpx"&gt;-&lt;/span&gt;&lt;/strong&gt; km/h&lt;/div&gt;
 &lt;div&gt;&lt;small&gt;FC Moy&lt;/small&gt;&lt;br&gt;&lt;strong id="hr-20251208.gpx"&gt;-&lt;/strong&gt; bpm&lt;/div&gt;
 &lt;div&gt;&lt;small&gt;Cadence Moy&lt;/small&gt;&lt;br&gt;&lt;strong id="cad-20251208.gpx"&gt;-&lt;/strong&gt; rpm&lt;/div&gt;
 &lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
 (function() {
 const gpxUrl = "/gpx/20251208.gpx";
 const idSuffix = "20251208.gpx";

 fetch(gpxUrl)
 .then(response =&gt; response.text())
 .then(xmlRaw =&gt; {
 
 let gpx = new gpxParser();
 gpx.parse(xmlRaw);

 if (!gpx.tracks || gpx.tracks.length === 0) return;
 let track = gpx.tracks[0];
 let pts = track.points;

 
 var map = L.map('map-' + idSuffix);
 L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
 var coordinates = pts.map(p =&gt; [p.lat, p.lon]);
 L.polyline(coordinates, {color: '#e74c3c', weight: 3}).addTo(map);
 map.fitBounds(L.polyline(coordinates).getBounds());

 
 document.getElementById('dist-' + idSuffix).innerText = (track.distance.total / 1000).toFixed(2);
 document.getElementById('elev-p-' + idSuffix).innerText = Math.round(track.elevation.pos || 0);
 document.getElementById('elev-m-' + idSuffix).innerText = Math.round(track.elevation.neg || 0);

 
 let startTime = new Date(pts[0].time);
 let endTime = new Date(pts[pts.length - 1].time);
 let durationSec = Math.floor((endTime - startTime) / 1000);
 document.getElementById('time-' + idSuffix).innerText = Math.floor(durationSec / 3600) + "h " + Math.floor((durationSec % 3600) / 60) + "m";

 
 let avgSpeed = (track.distance.total / 1000) / (durationSec / 3600);
 document.getElementById('speed-av-' + idSuffix).innerText = avgSpeed.toFixed(1);

 

 
 const hrValues = [...xmlRaw.matchAll(/&lt;gpxtpx:hr&gt;(\d+)&lt;\/gpxtpx:hr&gt;/g)].map(m =&gt; parseInt(m[1]));
 const cadValues = [...xmlRaw.matchAll(/&lt;gpxtpx:cad&gt;(\d+)&lt;\/gpxtpx:cad&gt;/g)].map(m =&gt; parseInt(m[1]));
 const speedValues = [...xmlRaw.matchAll(/&lt;gpxtpx:speed&gt;([\d.]+)&lt;\/gpxtpx:speed&gt;/g)].map(m =&gt; parseFloat(m[1]));

 
 if (hrValues.length &gt; 0) {
 const hrAvg = hrValues.reduce((a, b) =&gt; a + b) / hrValues.length;
 document.getElementById('hr-' + idSuffix).innerText = Math.round(hrAvg);
 }

 
 if (cadValues.length &gt; 0) {
 const cadAvg = cadValues.reduce((a, b) =&gt; a + b) / cadValues.length;
 document.getElementById('cad-' + idSuffix).innerText = Math.round(cadAvg);
 }

 
 if (speedValues.length &gt; 0) {
 const maxSpeedms = Math.max(...speedValues);
 document.getElementById('speed-mx-' + idSuffix).innerText = (maxSpeedms * 3.6).toFixed(1);
 } else if (track.stats.maxSpeed) {
 
 document.getElementById('speed-mx-' + idSuffix).innerText = (track.stats.maxSpeed * 3.6).toFixed(1);
 }
 })
 .catch(err =&gt; console.error("Erreur:", err));
 })();
&lt;/script&gt;</description></item><item><title>Parcours du 12/08/2025</title><link>https://github-mc1258.github.io/activites/20250812/</link><pubDate>Tue, 12 Aug 2025 00:00:00 +0200</pubDate><guid>https://github-mc1258.github.io/activites/20250812/</guid><description>&lt;p&gt;Parcours du 12/08/2025 exporté depuis Oruxmaps.&lt;/p&gt;
