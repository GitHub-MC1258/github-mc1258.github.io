A;        const gpxUrl = &#34;/gpx/20260224.gpx&#34;;&#xA;        const idSuffix = &#34;20260224.gpx&#34;;&#xA;&#xA;        fetch(gpxUrl)&#xA;            .then(response =&gt; response.text())&#xA;            .then(xmlRaw =&gt; {&#xA;                &#xA;                let gpx = new gpxParser();&#xA;                gpx.parse(xmlRaw);&#xA;&#xA;                if (!gpx.tracks || gpx.tracks.length === 0) return;&#xA;                let track = gpx.tracks[0];&#xA;                let pts = track.points;&#xA;&#xA;                &#xA;                var map = L.map(&#39;map-&#39; + idSuffix);&#xA;                L.tileLayer(&#39;https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png&#39;).addTo(map);&#xA;                var coordinates = pts.map(p =&gt; [p.lat, p.lon]);&#xA;                L.polyline(coordinates, {color: &#39;#e74c3c&#39;, weight: 3}).addTo(map);&#xA;                map.fitBounds(L.polyline(coordinates).getBounds());&#xA;&#xA;                &#xA;                document.getElementById(&#39;dist-&#39; + idSuffix).innerText = (track.distance.total / 1000).toFixed(2);&#xA;                document.getElementById(&#39;elev-p-&#39; + idSuffix).innerText = Math.round(track.elevation.pos || 0);&#xA;                document.getElementById(&#39;elev-m-&#39; + idSuffix).innerText = Math.round(track.elevation.neg || 0);&#xA;&#xA;                &#xA;                let startTime = new Date(pts[0].time);&#xA;                let endTime = new Date(pts[pts.length - 1].time);&#xA;                let durationSec = Math.floor((endTime - startTime) / 1000);&#xA;                document.getElementById(&#39;time-&#39; + idSuffix).innerText = Math.floor(durationSec / 3600) + &#34;h &#34; + Math.floor((durationSec % 3600) / 60) + &#34;m&#34;;&#xA;&#xA;                &#xA;                let avgSpeed = (track.distance.total / 1000) / (durationSec / 3600);&#xA;                document.getElementById(&#39;speed-av-&#39; + idSuffix).innerText = avgSpeed.toFixed(1);&#xA;&#xA;         